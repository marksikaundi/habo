# Appwrite — add APPWRITE_API_KEY for schema setup (npm run appwrite:setup)
# Get key from Appwrite Console → API Keys → scopes: databases.write
# APPWRITE_API_KEY=

EXPO_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=your_project_id
EXPO_PUBLIC_APPWRITE_DATABASE_ID=your_database_id
EXPO_PUBLIC_APPWRITE_PLATFORM=com.habora.habo

EXPO_PUBLIC_APPWRITE_COLLECTION_TASKS=tasks
EXPO_PUBLIC_APPWRITE_COLLECTION_GOALS=goals
EXPO_PUBLIC_APPWRITE_COLLECTION_NOTES=notes
EXPO_PUBLIC_APPWRITE_COLLECTION_NOTIFICATIONS=notifications
EXPO_PUBLIC_APPWRITE_COLLECTION_USER_STATS=user_stats
EXPO_PUBLIC_APPWRITE_COLLECTION_WORKSPACES=workspaces
EXPO_PUBLIC_APPWRITE_COLLECTION_WORKSPACE_MEMBERS=workspace_members
EXPO_PUBLIC_APPWRITE_COLLECTION_WORKSPACE_ACTIVITY=workspace_activity
EXPO_PUBLIC_APPWRITE_COLLECTION_WORKSPACE_TASKS=workspace_tasks
