# Appwrite environment variables
# Copy to .env in the project root and fill in your values.

EXPO_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=your_project_id
EXPO_PUBLIC_APPWRITE_DATABASE_ID=habora
EXPO_PUBLIC_APPWRITE_PLATFORM=com.habora.app

# Optional — override default collection IDs
# EXPO_PUBLIC_APPWRITE_COLLECTION_TASKS=tasks
# EXPO_PUBLIC_APPWRITE_COLLECTION_GOALS=goals
# EXPO_PUBLIC_APPWRITE_COLLECTION_NOTES=notes
# EXPO_PUBLIC_APPWRITE_COLLECTION_NOTIFICATIONS=notifications
# EXPO_PUBLIC_APPWRITE_COLLECTION_USER_STATS=user_stats
